# Banco de dados (SQLite local para começar; Postgres quando for pra produção)
DATABASE_URL="file:./dev.db"

# IA que gera os posts (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=""

# Agregador de publicação: IG + FB + LinkedIn com uma chave (app.ayrshare.com)
AYRSHARE_API_KEY=""

# Banco de fotos automáticas para os posts (pexels.com/api — grátis, sem cartão)
PEXELS_API_KEY=""

# Subtítulo exibido na prévia do LinkedIn (deixe vazio para não mostrar nada)
NEXT_PUBLIC_USER_HEADLINE=""

# Feeds de notícias do radar (separados por vírgula)
RADAR_FEEDS="https://www.orlandosentinel.com/arcio/rss/,https://floridarealtors.org/rss.xml"

# Meta Marketing API — controle de verba e anúncios (opcional)
META_ACCESS_TOKEN=""   # Token de acesso da Meta Marketing API
META_AD_ACCOUNT_ID=""  # ID da conta de anúncios (formato: act_XXXXXXXXXX)

# Forçar modelo específico para todas as chamadas (sobrescreve a seleção automática)
# Útil para controle de custos, testes ou A/B. Deixe em branco para usar seleção automática.
# Opções: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-6
# FORCE_MODEL=claude-sonnet-4-6
