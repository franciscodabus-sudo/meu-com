generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Campaign {
  id        String   @id @default(cuid())
  name      String
  brief     String
  objective String?
  stageFlow String   @default("atrair,educar,conectar,converter")
  status    String   @default("ativa") // ativa | pausada | concluida
  startsAt  DateTime?
  posts     Post[]
  createdAt DateTime @default(now())
}

model Post {
  id          String        @id @default(cuid())
  campaign    Campaign?     @relation(fields: [campaignId], references: [id])
  campaignId  String?
  profile     BrandProfile? @relation(fields: [profileId], references: [id])
  profileId   String?
  channel     String        // instagram | facebook | linkedin | x
  format      String        @default("post") // post | carrossel | reel | artigo
  stage       String?       // atrair | educar | conectar | converter
  title       String
  caption     String
  hashtags    String?
  mediaUrl    String?
  whyNow      String?       // a justificativa do CMO ("Por que agora?")
  status      String        @default("pending") // pending | approved | scheduled | published | skipped
  scheduledAt DateTime?
  publishedAt DateTime?
  ayrshareId  String?
  createdAt   DateTime      @default(now())
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String   @unique
  kind      String   @default("foto") // foto | video | arte
  tags      String?  // "casa,clima,furacao"
  source    String   @default("upload") // upload | pexels | canva | drive
  createdAt DateTime @default(now())
}

model RadarItem {
  id         String    @id @default(cuid())
  kind       String    // noticia | concorrente
  title      String
  summary    String?
  sourceUrl  String?
  sourceName String?
  heat       Int       @default(0)
  usedAt     DateTime?
  deletedAt  DateTime? // marcado como descartado pelo usuário — nunca volta
  createdAt  DateTime  @default(now())
}

model RadarSource {
  id        String   @id @default(cuid())
  url       String   @unique
  kind      String   @default("rss") // rss | website | instagram
  name      String
  active    Boolean  @default(true)
  warning   String?  // aviso de qualidade da fonte
  createdAt DateTime @default(now())
}

model Channel {
  id        String   @id @default(cuid())
  name      String   @unique // instagram | facebook | linkedin | tiktok
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("admin") // admin | viewer
  createdAt DateTime @default(now())
}

model BrandProfile {
  id             String   @id @default(cuid())
  name           String   @unique  // slug único do perfil
  displayName    String            // nome a exibir nos posts
  avatarColor    String   @default("#0E5F66") // cor do avatar no seletor
  descricao      String?           // descrição/negócio
  publicoAlvo    String?           // público-alvo (audience)
  tomDeVoz       String?           // palavras a usar (toneWords)
  tomEvitar      String?           // palavras a EVITAR (toneAvoid)
  idioma         String   @default("pt-BR")
  contato        String?           // site ou link de contato
  produtos       String?           // produtos / serviços
  frequencia     String?           // posts/semana (texto livre)
  channelsActive String?           // JSON: ["instagram","linkedin"]
  objetivo       String   @default("engajamento") // leads | autoridade | engajamento
  notasLivres    String?           // notas livres para a IA
  ativo          Boolean  @default(false)
  pausado        Boolean  @default(false) // toggle ativo/pausado na UI
  radarAtivo     Boolean  @default(false)
  posts          Post[]
  createdAt      DateTime @default(now())
}
